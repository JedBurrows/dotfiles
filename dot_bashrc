# If not running interactively, don't do anything (leave this at the top of this file)
[[ $- != *i* ]] && return

# Shell base: omarchy's own config when present, otherwise the portable fallback.
if [[ -f ~/.local/share/omarchy/default/bash/rc ]]; then
  source ~/.local/share/omarchy/default/bash/rc
elif [[ -f ~/.config/bash/rc ]]; then
  source ~/.config/bash/rc
fi

# ============ personal ============
# Loads on every machine, layered on top of whichever base was sourced above.
alias vim='nvim'

export EDITOR=vim

export PATH="$HOME/.local/bin:$PATH"

if command -v mise &> /dev/null; then
  eval "$(mise activate bash)"
fi

# pnpm
export PNPM_HOME="/home/jed/.local/share/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac
# pnpm end
